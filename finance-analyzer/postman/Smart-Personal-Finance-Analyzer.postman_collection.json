{
  "info": {
    "name": "Smart Personal Finance Analyzer",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Dashboard Summary",
      "request": {
        "method": "GET",
        "url": "http://localhost:8080/api/dashboard"
      }
    },
    {
      "name": "List Transactions",
      "request": {
        "method": "GET",
        "url": "http://localhost:8080/api/transactions"
      }
    },
    {
      "name": "Create Transaction",
      "request": {
        "method": "POST",
        "url": "http://localhost:8080/api/transactions?categoryId=4",
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "title", "value": "Lunch" },
            { "key": "amount", "value": "250" },
            { "key": "transactionDate", "value": "2026-06-29" },
            { "key": "note", "value": "Team lunch" }
          ]
        }
      }
    },
    {
      "name": "Delete Transaction",
      "request": {
        "method": "DELETE",
        "url": "http://localhost:8080/api/transactions/1"
      }
    }
  ]
}
